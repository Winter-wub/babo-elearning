generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  role          Role      @default(STUDENT)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                Account[]
  videoPermissions        VideoPermission[]        @relation("UserPermissions")
  grantedPermissions      VideoPermission[]        @relation("GrantedByAdmin")
  policyAgreements        PolicyAgreement[]
  verificationAttempts    VerificationAttempt[]
  emailVerificationTokens EmailVerificationToken[]
  createdInviteLinks      InviteLink[]             @relation("InviteLinkCreator")
  inviteRedemptions       InviteLinkRedemption[]
  chatConversations       AdminChatConversation[]
  blogPosts               BlogPost[]
  exerciseAttempts        ExerciseAttempt[]

  @@index([email])
  @@index([role])
}

/**
 * Stores pending registrations awaiting OTP email verification.
 * User record is only created after successful OTP verification + profile completion.
 *
 * Flow: email → OTP verify → complete profile → User created.
 */
model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  otpHash      String
  otpExpiresAt DateTime
  attempts     Int      @default(0)
  verified     Boolean  @default(false)
  sessionToken String?  @unique // set after OTP verified, authorises step 3
  inviteCode   String? // carries invite link code through OTP flow
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([sessionToken])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String?
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

/**
 * Tracks verification attempt history for rate limiting (legacy users).
 * Records are automatically cleaned up after 24 hours by application logic.
 */
model VerificationAttempt {
  id        String   @id @default(cuid())
  userId    String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, success, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Video {
  id           String   @id @default(cuid())
  title        String
  description  String?
  s3Key        String   @unique
  duration     Int // seconds, max 3600
  thumbnailUrl String? // legacy: external URL — prefer thumbnailKey for R2-stored images
  thumbnailKey String? // R2 object key, e.g. "video-thumbnails/<videoId>/<uuid>.<ext>"
  thumbnailAlt String? // alt text for accessibility
  isActive     Boolean  @default(true)
  playCount    Int      @default(0)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  permissions VideoPermission[]
  playlists   PlaylistVideo[]
  materials   CourseMaterial[]
  exercises   Exercise[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([playCount])
}

model VideoPermission {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  grantedAt DateTime @default(now())
  grantedBy String

  // Time-based access control (all nullable = permanent access)
  validFrom    DateTime? // null = immediately valid from grantedAt
  validUntil   DateTime? // null = never expires (permanent)
  durationDays  Int? // audit hint: original admin-chosen duration in days
  durationHours Int? // audit hint: original admin-chosen duration in hours

  user  User  @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  admin User  @relation("GrantedByAdmin", fields: [grantedBy], references: [id])

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
  @@index([validUntil])
}

model CourseMaterial {
  id          String   @id @default(cuid())
  videoId     String
  filename    String
  s3Key       String   @unique
  contentType String
  fileSize    Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([videoId, sortOrder])
}

model PolicyAgreement {
  id        String   @id @default(cuid())
  userId    String
  agreedAt  DateTime @default(now())
  ipAddress String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Playlist {
  id           String   @id @default(cuid())
  title        String
  description  String?
  thumbnailUrl String? // legacy: external URL — prefer thumbnailKey for R2-stored images
  thumbnailKey String? // R2 object key, e.g. "playlist-thumbnails/<playlistId>/<uuid>.<ext>"
  thumbnailAlt String? // alt text for accessibility
  slug         String   @unique
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  videos    PlaylistVideo[]
  blogPosts BlogPostPlaylist[]

  @@index([isActive])
  @@index([isFeatured])
}

model PlaylistVideo {
  playlistId String
  videoId    String
  position   Int    @default(0)

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video    Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([playlistId, videoId])
  @@index([playlistId])
}

// -----------------------------------------------------------------------
// Invite Links — Admin-created registration links with pre-set permissions
// -----------------------------------------------------------------------

model InviteLink {
  id                 String    @id @default(cuid())
  code               String    @unique
  label              String
  videoIds           String[]

  // Permission time config (decomposed PermissionTimeConfig)
  timeMode           String // "permanent" | "relative" | "absolute"
  durationDays       Int?
  durationHours      Int?
  validFrom          DateTime?
  validUntil         DateTime?

  // Link constraints
  maxRedemptions     Int?
  currentRedemptions Int       @default(0)
  expiresAt          DateTime?
  isRevoked          Boolean   @default(false)

  createdBy          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  creator     User                   @relation("InviteLinkCreator", fields: [createdBy], references: [id])
  redemptions InviteLinkRedemption[]

  @@index([code])
  @@index([createdBy])
  @@index([expiresAt])
}

model InviteLinkRedemption {
  id           String   @id @default(cuid())
  inviteLinkId String
  userId       String
  redeemedAt   DateTime @default(now())

  inviteLink InviteLink @relation(fields: [inviteLinkId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inviteLinkId, userId])
  @@index([inviteLinkId])
  @@index([userId])
}

// -----------------------------------------------------------------------
// CMS — Admin-managed site content
// -----------------------------------------------------------------------

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "about.hero.title", "about.highlight.1"
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// -----------------------------------------------------------------------
// AI Chat — Admin chat conversations with AI assistant (Beta)
// -----------------------------------------------------------------------

model AdminChatConversation {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  title     String?
  messages  AdminChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
}

model AdminChatMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   AdminChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String @db.Text
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

// -----------------------------------------------------------------------
// Blog — Public articles authored by admins
// -----------------------------------------------------------------------

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  excerpt          String?        @db.VarChar(500)
  content          String         @db.Text
  featuredImageKey  String?
  featuredImageAlt  String?
  status           BlogPostStatus @default(DRAFT)
  publishedAt      DateTime?
  authorId         String?

  author     User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categories BlogPostCategory[]
  playlists  BlogPostPlaylist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
  @@index([authorId])
}

model BlogCategory {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String?
  color       String @default("bg-blue-100 text-blue-700")
  sortOrder   Int    @default(0)

  posts BlogPostCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([sortOrder])
}

model BlogPostCategory {
  postId     String
  categoryId String

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([postId])
  @@index([categoryId])
}

model BlogPostPlaylist {
  postId     String
  playlistId String
  position   Int    @default(0)

  post     BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([postId, playlistId])
  @@index([postId])
  @@index([playlistId])
}

// -----------------------------------------------------------------------
// Audit Log — Tracks admin actions for accountability
// -----------------------------------------------------------------------

// -----------------------------------------------------------------------
// Exercises — Pre-test / Post-test for Videos
// -----------------------------------------------------------------------

enum ExerciseType {
  PRE_TEST
  POST_TEST
}

enum QuestionType {
  SHORT_ANSWER
  PARAGRAPH
  MULTIPLE_CHOICE
  CHECKBOXES
  DROPDOWN
  LINEAR_SCALE
  MATCHING
  TRUE_FALSE
  FILL_IN_BLANK
}

model Exercise {
  id           String       @id @default(cuid())
  videoId      String
  type         ExerciseType
  title        String
  description  String?
  passingScore Int          @default(80) // percentage 0–100
  maxAttempts  Int?         // null = unlimited retakes
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  video     Video              @relation(fields: [videoId], references: [id], onDelete: Cascade)
  questions ExerciseQuestion[]
  attempts  ExerciseAttempt[]

  @@unique([videoId, type]) // one pre-test + one post-test per video
  @@index([videoId])
}

model ExerciseQuestion {
  id         String       @id @default(cuid())
  exerciseId String
  type       QuestionType
  text       String       @db.Text
  required   Boolean      @default(true)
  points     Int          @default(1)
  sortOrder  Int          @default(0)
  config     Json         // type-specific options & correct answer
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  answers  StudentAnswer[]

  @@index([exerciseId, sortOrder])
}

model ExerciseAttempt {
  id           String    @id @default(cuid())
  exerciseId   String
  userId       String
  score        Int?      // percentage, null = in progress
  totalPoints  Int?
  earnedPoints Int?
  passed       Boolean?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers  StudentAnswer[]

  @@index([exerciseId])
  @@index([userId])
  @@index([userId, exerciseId])
}

model StudentAnswer {
  id            String  @id @default(cuid())
  attemptId     String
  questionId    String
  answer        Json    // flexible: string, number, boolean, string[], Record<string,string>
  isCorrect     Boolean? // null = pending manual review
  pointsAwarded Int     @default(0)

  attempt  ExerciseAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ExerciseQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

// -----------------------------------------------------------------------
// Audit Log — Tracks admin actions for accountability
// -----------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userEmail  String
  action     String   // e.g. "USER_CREATE", "VIDEO_DELETE", "PERMISSION_GRANT"
  entityType String   // e.g. "User", "Video", "Faq"
  entityId   String?  // null for bulk or non-entity actions
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([createdAt, action, entityType]) // composite for filtered admin page queries
}
