# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/elearning?schema=public"

# ============================================================
# Auth.js v5
# Generate AUTH_SECRET with: openssl rand -base64 32
# ============================================================
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ============================================================
# Cloudflare R2 (S3-compatible object storage)
# ============================================================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="elearning-videos"

# ============================================================
# Mailjet SMTP (email verification)
# Use your Mailjet API Key / Secret Key as SMTP credentials.
# SMTP host: in-v3.mailjet.com  port: 587 (STARTTLS)
# ============================================================
MAILJET_SMTP_HOST="in-v3.mailjet.com"
MAILJET_SMTP_PORT="587"
MAILJET_SMTP_USER=""        # Mailjet API Key (public key)
MAILJET_SMTP_PASS=""        # Mailjet Secret Key
MAIL_FROM_EMAIL="noreply@yourdomain.com"
MAIL_FROM_NAME="E Learning"

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# Google Tag Manager
# ============================================================
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
