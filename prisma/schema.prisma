generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  description        String?
  contactEmail       String?
  logoUrl            String?
  maxMembers         Int?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  contactSubmissions ContactSubmission[]
  faqs               Faq[]
  playlists          Playlist[]
  policyAgreements   PolicyAgreement[]
  siteContent        SiteContent[]
  members            TenantMember[]
  videos             Video[]
  videoPermissions   VideoPermission[]

  @@index([isActive])
}

model TenantMember {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(STUDENT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([role])
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  passwordHash       String?
  name               String?
  role               Role              @default(STUDENT)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  accounts           Account[]
  policyAgreements   PolicyAgreement[]
  tenantMembers      TenantMember[]
  grantedPermissions VideoPermission[] @relation("GrantedByAdmin")
  videoPermissions   VideoPermission[] @relation("UserPermissions")

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Video {
  id           String            @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  s3Key        String
  duration     Int
  thumbnailUrl String?
  isActive     Boolean           @default(true)
  playCount    Int               @default(0)
  isFeatured   Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  playlists    PlaylistVideo[]
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions  VideoPermission[]

  @@unique([tenantId, s3Key])
  @@index([tenantId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([playCount])
}

model VideoPermission {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  videoId      String
  grantedAt    DateTime  @default(now())
  grantedBy    String
  validFrom    DateTime?
  validUntil   DateTime?
  durationDays Int?
  admin        User      @relation("GrantedByAdmin", fields: [grantedBy], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User      @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)
  video        Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, videoId])
  @@index([tenantId])
  @@index([userId])
  @@index([videoId])
  @@index([validUntil])
}

model PolicyAgreement {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  agreedAt  DateTime @default(now())
  ipAddress String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Playlist {
  id           String          @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  thumbnailUrl String?
  slug         String
  isActive     Boolean         @default(true)
  isFeatured   Boolean         @default(false)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  videos       PlaylistVideo[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([isActive])
  @@index([isFeatured])
}

model PlaylistVideo {
  playlistId String
  videoId    String
  position   Int      @default(0)
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([playlistId, videoId])
  @@index([playlistId])
}

model SiteContent {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([key])
}

model Faq {
  id        String   @id @default(cuid())
  tenantId  String
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isActive, sortOrder])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isRead])
  @@index([createdAt])
}

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum TenantRole {
  OWNER
  ADMIN
  STUDENT
}
