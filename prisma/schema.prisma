generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

enum TenantRole {
  OWNER
  ADMIN
  STUDENT
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            TenantMember[]
  videos             Video[]
  playlists          Playlist[]
  siteContent        SiteContent[]
  faqs               Faq[]
  contactSubmissions ContactSubmission[]
  videoPermissions   VideoPermission[]
  policyAgreements   PolicyAgreement[]

  @@index([isActive])
}

model TenantMember {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(STUDENT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([role])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  role         Role     @default(STUDENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts           Account[]
  tenantMembers      TenantMember[]
  videoPermissions   VideoPermission[] @relation("UserPermissions")
  grantedPermissions VideoPermission[] @relation("GrantedByAdmin")
  policyAgreements   PolicyAgreement[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Video {
  id           String   @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  s3Key        String
  duration     Int // seconds, max 3600
  thumbnailUrl String?
  isActive     Boolean  @default(true)
  playCount    Int      @default(0)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions VideoPermission[]
  playlists   PlaylistVideo[]

  @@unique([tenantId, s3Key])
  @@index([tenantId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([playCount])
}

model VideoPermission {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  videoId   String
  grantedAt DateTime @default(now())
  grantedBy String

  // Time-based access control (all nullable = permanent access)
  validFrom    DateTime? // null = immediately valid from grantedAt
  validUntil   DateTime? // null = never expires (permanent)
  durationDays Int? // audit hint: original admin-chosen duration in days

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)
  video  Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  admin  User   @relation("GrantedByAdmin", fields: [grantedBy], references: [id])

  @@unique([tenantId, userId, videoId])
  @@index([tenantId])
  @@index([userId])
  @@index([videoId])
  @@index([validUntil])
}

model PolicyAgreement {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  agreedAt  DateTime @default(now())
  ipAddress String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Playlist {
  id           String   @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  thumbnailUrl String?
  slug         String
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  videos PlaylistVideo[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([isActive])
  @@index([isFeatured])
}

model PlaylistVideo {
  playlistId String
  videoId    String
  position   Int    @default(0)

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video    Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([playlistId, videoId])
  @@index([playlistId])
}

// -----------------------------------------------------------------------
// CMS — Admin-managed site content
// -----------------------------------------------------------------------

model SiteContent {
  id        String   @id @default(cuid())
  tenantId  String
  key       String // e.g. "about.hero.title", "about.highlight.1"
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([key])
}

model Faq {
  id        String   @id @default(cuid())
  tenantId  String
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isActive, sortOrder])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isRead])
  @@index([createdAt])
}
