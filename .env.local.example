# =============================================================================
# .env.local.example — Docker development environment
#
# Copy this file to .env.local before running `docker compose up`.
# Values are pre-filled to work with the services defined in docker-compose.yml.
#
# NEVER commit .env.local — it is listed in .gitignore.
# =============================================================================

# ============================================================
# Database — points at the 'db' service inside Docker Compose
# ============================================================
# Host is the compose service name; port is the internal 5432 (not the host-
# mapped 5433) because the app container is on the same Docker network.
DATABASE_URL="postgresql://elearning:elearning_dev_password@db:5432/elearning?schema=public"

POSTGRES_USER=elearning
POSTGRES_PASSWORD=elearning_dev_password
POSTGRES_DB=elearning

# ============================================================
# Auth.js v5
# This is a dev-only secret. Generate a real one for production:
#   openssl rand -base64 32
# ============================================================
AUTH_SECRET="dev-only-secret-replace-before-deploying-to-any-real-environment"
AUTH_URL="http://localhost:3000"

# ============================================================
# Object Storage — MinIO (local substitute for Cloudflare R2)
#
# The app container reaches MinIO via the Docker network using the
# service name 'minio'. R2_ENDPOINT is an extra env var consumed by
# the AWS SDK client to redirect requests to MinIO instead of AWS.
# ============================================================
R2_ENDPOINT="http://minio:9000"
R2_ACCOUNT_ID="local"
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"
R2_BUCKET_NAME="elearning-videos"

# MinIO console credentials (same values used above)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================================
# App
# NEXT_PUBLIC_* vars are baked in at build time by Next.js.
# For the production Docker build this is set via a build arg.
# For local dev (pnpm dev on host) keep this as localhost:3000.
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
